        "\n",
        "#entrada\n",
        "a = int(input(\"digite um numero: \"))\n",
        "b = int(input(\"digite um numero: \"))\n",
        "\n",
        "#processamento\n",
        "soma = a + b\n",
        "multi = a * b\n",
